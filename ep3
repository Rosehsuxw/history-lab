        // ============ Counterfactual Tree ============
        function toggleBranch(header) {
            var node = header.closest('.branch-node');
            var details = node.querySelector('.branch-details');
            var isOpen = node.classList.contains('open');
            if (isOpen) { details.style.display = 'none'; node.classList.remove('open'); }
            else { details.style.display = 'block'; node.classList.add('open'); }
        }

        // ============ Decision Card ============
        function toggleDecisionCard(header) {
            var card = header.closest('.decision-card');
            var body = card.querySelector('.decision-card-body');
            var toggle = card.querySelector('.decision-card-toggle');
            if (body.style.display === 'none') {
                body.style.display = 'block';
                toggle.innerHTML = '<span class="zh">\u6536\u8d77 \u2191</span><span class="en">Collapse \u2191</span>';
            } else {
                body.style.display = 'none';
                toggle.innerHTML = '<span class="zh">\u5c55\u5f00 \u2193</span><span class="en">Expand \u2193</span>';
            }
        }

        // ============ Reset ============
        function resetVotes() {
            if (confirm(isEN() ? 'Reset your votes? You can re-experience the full flow!\n(Previous votes remain in statistics)' : '\u786e\u5b9a\u8981\u91cd\u7f6e\u4f60\u7684\u6295\u7968\u5417\uff1f\u53ef\u4ee5\u91cd\u65b0\u4f53\u9a8c\u5b8c\u6574\u6d41\u7a0b\uff01\n\uff08\u4f60\u4e4b\u524d\u7684\u6295\u7968\u5df2\u8ba1\u5165\u7edf\u8ba1\uff0c\u91cd\u7f6e\u540e\u53ef\u91cd\u65b0\u9009\u62e9\uff09')) {
                localStorage.removeItem(STORAGE_KEY);
                location.reload();
            }
        }

        // ============ Language Toggle ============
        function toggleLang() {
            document.body.classList.toggle('lang-en');
            var btn = document.getElementById('langToggle');
            var isEnglish = document.body.classList.contains('lang-en');
            btn.textContent = isEnglish ? '\u4e2d' : 'EN';
            if (isEnglish) { btn.classList.add('active'); } else { btn.classList.remove('active'); }
            sessionStorage.setItem('lang', isEnglish ? 'en' : 'zh');
            loadVoteStats();
            if (userState.userChoice && userState.userExperiment) {
                showPersonality(userState.userChoice, userState.userExperiment);
            }
        }

        // ============ Page Load ============
        window.addEventListener('load', function() {
            if (sessionStorage.getItem('lang') === 'en') {
                document.body.classList.add('lang-en');
                document.getElementById('langToggle').textContent = '\u4e2d';
                document.getElementById('langToggle').classList.add('active');
            }
            loadVoteStats();
            if (userState.hasVotedChoice) {
                var card = document.querySelector('.option-card[data-option="' + userState.userChoice + '"]');
                if (card) {
                    card.classList.add('selected');
                    document.querySelectorAll('.option-card').forEach(function(c) { c.classList.add('voted'); });
                    document.getElementById('vote-result-area').style.display = 'block';
                }
            }
            if (userState.hasVotedExperiment) {
                var ecard = document.querySelector('.exp-option[data-exp="' + userState.userExperiment + '"]');
                if (ecard) {
                    ecard.classList.add('selected');
                    ecard.style.background = 'rgba(16, 185, 129, 0.1)';
                    document.querySelectorAll('.exp-option').forEach(function(c) { c.style.cursor = 'default'; });
                    document.getElementById('exp-result-area').style.display = 'block';
                }
            }
            if (userState.userChoice && userState.userExperiment) {
                setTimeout(function() { showPersonality(userState.userChoice, userState.userExperiment); }, 800);
            }
        });
    </script>
</body>
</html>
