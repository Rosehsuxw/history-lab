            // 恢复历史选择状态
            if (userState.hasVotedChoice) {
                const card = document.querySelector(`.option-card[data-option="${userState.userChoice}"]`);
                if (card) {
                    card.classList.add('selected');
                    document.querySelectorAll('.option-card').forEach(c => c.classList.add('voted'));
                    document.getElementById('vote-result-area').style.display = 'block';
                }
            }
            
            // 恢复实验投票状态
            if (userState.hasVotedExperiment) {
                const card = document.querySelector(`.exp-option[data-exp="${userState.userExperiment}"]`);
                if (card) {
                    card.classList.add('selected');
                    card.style.background = 'rgba(16, 185, 129, 0.1)';
                    document.querySelectorAll('.exp-option').forEach(c => c.style.cursor = 'default');
                }
                document.getElementById('exp-result-area').style.display = 'block';
            }
            
            // 如果两次都投了，显示人物画像
            if (userState.userChoice && userState.userExperiment) {
                setTimeout(() => showPersonality(userState.userChoice, userState.userExperiment), 800);
            }
        });
    </script>
</body>
</html>
